# =========================================================
# SAR Guardian — Environment Configuration
# =========================================================

# PostgreSQL
POSTGRES_USER=sar_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=sar_guardian
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sar_admin:change_me_in_production@db:5432/sar_guardian

# JWT
JWT_SECRET_KEY=replace-with-256-bit-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI (or Bedrock-compatible)
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL_NAME=gpt-4
LLM_TEMPERATURE=0.2

# Redis (optional caching)
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMA_PERSIST_DIR=/app/data/chromadb

# Application
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
